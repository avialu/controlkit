# Copy to .env and fill in the right values for your machine.
PORT=4000

# Postgres connection (used by `pg` Pool).
#
# • Homebrew postgresql@14 on macOS uses your macOS username with NO password.
#     DATABASE_URL=postgres://YOUR_MAC_USERNAME@localhost:5432/controlkit
#   e.g.  postgres://avialurie@localhost:5432/controlkit
#
# • The Docker / Linux default is the `postgres` superuser with a password:
#     DATABASE_URL=postgres://postgres:postgres@localhost:5432/controlkit
DATABASE_URL=postgres://YOUR_MAC_USERNAME@localhost:5432/controlkit

# Comma-separated origins allowed by CORS for the portal
CORS_ORIGIN=http://localhost:5173
